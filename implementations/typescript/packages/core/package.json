{
  "name": "@uaf/core",
  "version": "1.0.0",
  "description": "UAF v1.0 payload types, validation, and CSV codec",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean --external zod && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
