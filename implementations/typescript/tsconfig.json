{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@uaf/core": ["packages/core/src/index.ts"],
      "@uaf/html": ["packages/html/src/index.ts"],
      "@uaf/pdf": ["packages/pdf/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
